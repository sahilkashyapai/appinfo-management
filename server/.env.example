# Copy this file to .env and fill in real values. Never commit .env.

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (Atlas UI -> Connect -> Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/aii_celebrations?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=8h

# CORS - the client's origin
CLIENT_ORIGIN=http://localhost:5173

# SMTP (used by Nodemailer to actually send birthday/anniversary/event emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=noreply@appliedinformation.in
SMTP_FROM_NAME=Applied Information India

# Seed superadmin (used only by npm run seed)
SEED_SUPERADMIN_EMAIL=superadmin@aii.in
SEED_SUPERADMIN_PASSWORD=Admin@123
